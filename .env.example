# Data layer duality: switch between mongodb | dynamodb
DATA_PROVIDER=mongodb

# MongoDB (local via docker-compose)
MONGODB_URI=mongodb://localhost:27017/interview-stack

# DynamoDB (local via docker-compose or AWS)
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_TABLE=Products

# API
API_PORT=4000
API_URL=http://localhost:4000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Deployment target: aws | kubernetes
DEPLOY_TARGET=kubernetes

# Auth (optional — set ENABLE_AUTH=true to require JWT for mutations)
JWT_SECRET=interview-dev-secret-change-in-production
ENABLE_AUTH=false

# Redis cache (optional — omit to disable caching)
REDIS_URL=redis://localhost:6379

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=100
