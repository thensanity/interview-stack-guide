# Copy to deploy/.env.deploy and edit before running ./scripts/deploy-oss.sh
#
# REQUIRED: point DOMAIN to your server's public hostname (DNS A record)

DOMAIN=interview.example.com
ACME_EMAIL=you@example.com

# Optional
DEPLOY_TARGET=kubernetes
JWT_SECRET=change-me-to-a-long-random-string
ENABLE_AUTH=false
RATE_LIMIT_MAX=200
