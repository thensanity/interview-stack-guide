{
  "dashboard": {
    "title": "Interview Stack API",
    "panels": [
      {
        "title": "Request Rate",
        "targets": [{ "expr": "rate(http_requests_total[5m])" }]
      },
      {
        "title": "Error Rate",
        "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m])" }]
      },
      {
        "title": "P95 Latency",
        "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))" }]
      }
    ]
  }
}
